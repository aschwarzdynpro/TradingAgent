# ─────────────────────────────────────────────────────────────────────────────
# IBKR Trading Agent — environment configuration
# Copy this file to ".env" and adjust. NEVER commit your real ".env".
# ─────────────────────────────────────────────────────────────────────────────

# --- Live trading master switch -------------------------------------------------
# Default is PAPER. Live trading requires BOTH:
#   1) LIVE_TRADING=true
#   2) An explicit interactive confirmation at startup.
# Leave this false unless you really mean it.
LIVE_TRADING=false

# --- IB Gateway / TWS connection ------------------------------------------------
# The agent connects to a locally running IB Gateway or TWS instance.
IB_HOST=127.0.0.1

# Port convention (do not mix these up):
#   4002 = IB Gateway PAPER
#   4001 = IB Gateway LIVE
#   7497 = TWS PAPER   (alternative)
#   7496 = TWS LIVE    (alternative)
IB_PAPER_PORT=4002
IB_LIVE_PORT=4001

# Unique client id for this API connection (any integer not used by another client).
IB_CLIENT_ID=17

# Connection timeout in seconds.
IB_TIMEOUT=20

# Optional: restrict the agent to a single IBKR account id (e.g. DU1234567 for paper).
# Leave empty to use the default account of the connected gateway.
IB_ACCOUNT=

# --- Paths ---------------------------------------------------------------------
# SQLite database for state + audit trail.
DB_PATH=data/trading_agent.sqlite

# Path to the strategy/risk/universe configuration.
CONFIG_PATH=config.yaml

# --- Logging -------------------------------------------------------------------
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
